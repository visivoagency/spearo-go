<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ── Required by App Store ── -->
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>

	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>

	<key>CFBundleDisplayName</key>
	<string>Spearo Go</string>

	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>

	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>

	<key>CFBundlePackageType</key>
	<string>APPL</string>

	<!-- ── watchOS (standalone watch-only app, no companion iOS app) ── -->
	<key>WKApplication</key>
	<true/>

	<key>WKWatchOnly</key>
	<true/>

	<!-- ── Minimum OS ── -->
	<key>MinimumOSVersion</key>
	<string>10.0</string>

	<!-- ── Location permissions ── -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Spearo Go uses your location to fetch surf and weather conditions for your current dive spot.</string>

	<!-- ── No tracking, no analytics ── -->
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<key>NSPrivacyTracking</key>
	<false/>

	<!-- ── Background refresh ── -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
	</array>

	<!-- ── App appearance — always dark ── -->
	<key>UIUserInterfaceStyle</key>
	<string>Dark</string>

	<!-- ── Export compliance — app uses only Apple's built-in HTTPS ── -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
