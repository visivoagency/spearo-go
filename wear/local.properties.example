# Release signing config — copy this file to local.properties and fill in values
# Generate a keystore: keytool -genkey -v -keystore spearogo-release.keystore -alias spearogo -keyalg RSA -keysize 2048 -validity 10000

RELEASE_STORE_FILE=../spearogo-release.keystore
RELEASE_STORE_PASSWORD=your_store_password
RELEASE_KEY_ALIAS=spearogo
RELEASE_KEY_PASSWORD=your_key_password
